# =============================================================================
# CamBridge client — Apache config (served by Apache at /cambridge/, like the
# Mirror SPA at /Mirror/). Requires `AllowOverride All` on the <Directory>.
# =============================================================================

<IfModule mod_mime.c>
  # iOS rejects text/plain manifests; the PWA spec wants this type.
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_headers.c>
  # A service worker must never be cached long-term, or users can get stuck on a
  # stale, broken version with no recovery path.
  <FilesMatch "^(sw\.js|registerSW\.js|workbox-.*\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # The SPA shell / landing — always revalidate.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Vite content-hashes asset filenames (e.g. index-AbCd1234.js) — cache forever.
  <FilesMatch "^.+\.[a-f0-9]{8,}\.(js|css|woff2?|ttf|svg|png|jpg|jpeg|gif|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# -----------------------------------------------------------------------------
# SPA history fallback. Real files (broadcaster.html, viewer.html, js/, css/)
# are served as themselves; anything else falls back to index.html so a future
# client-side router can take over.
# -----------------------------------------------------------------------------
RewriteEngine On
RewriteBase /cambridge/

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule . index.html [L]
