# ── CamBridge server config ─────────────────────────────────────────────────
# Copy to ".env" and fill in. Never commit your real .env.

# HTTP / WebSocket
# Bind to loopback — Apache terminates TLS and proxies to us (admin pattern).
# Use 0.0.0.0 only for direct LAN testing without a reverse proxy.
HOST=127.0.0.1
CAMBRIDGE_PORT=8447
NODE_ENV=production
LOG_LEVEL=info
BASE_PATH=/cambridge

# Reverse-proxy hops so req.ip is the real client (Apache in front). 1 is typical.
TRUST_PROXY_HOPS=1

# Allowed browser Origins for the WS upgrade. Empty = allow any (dev only).
# Production: set to your domain(s), e.g. https://cam.example.com
ALLOWED_ORIGINS=https://www.theundergroundrailroad.world
# OBS's embedded browser (CEF) often sends Origin "null" or none — allow it.
ALLOW_NULL_ORIGIN=true

# Public base URL for building broadcaster + OBS viewer links (no trailing /).
# If empty, links are derived from the incoming request host.
PUBLIC_BASE_URL=https://www.theundergroundrailroad.world

# ── Sessions / abuse limits (DoS resistance) ─────────────────────────────────
# A link is reclaimed when idle beyond SESSION_TTL_MS (abandoned) OR older than
# SESSION_MAX_MS (absolute cap — a passcode link must not live forever).
SESSION_TTL_MS=10800000            # 3h idle sweep
SESSION_MAX_MS=86400000            # 24h absolute max
PASSCODE_LENGTH=6
MAX_LIVE_SESSIONS=500
MAX_MESSAGE_BYTES=65536
HEARTBEAT_INTERVAL_MS=30000

# Link-creation flood control (per IP)
CREATE_RATE_LIMIT=20
CREATE_RATE_WINDOW_MS=60000
# WebSocket connection flood control (per IP)
WS_CONNECT_LIMIT=30
WS_CONNECT_WINDOW_MS=60000
# Passcode brute-force guard: bad-passcode joins per IP before the socket is dropped
JOIN_FAIL_LIMIT=10
JOIN_FAIL_WINDOW_MS=600000

# ── Accounts (OPTIONAL) ──────────────────────────────────────────────────────
# Off by default. The core (passcode-gated streaming) needs NO database. Set to
# true only if you want user accounts — then the DB / JWT / Email blocks below
# are required and migrations run on boot.
AUTH_ENABLED=false
# If accounts are on, require login to create a link (else anyone can create).
REQUIRE_AUTH_TO_CREATE=false

# ── ICE: STUN ────────────────────────────────────────────────────────────────
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ── ICE: TURN (coturn) ───────────────────────────────────────────────────────
# Required for hard NAT / CGNAT / cellular. coturn `use-auth-secret` scheme —
# the server mints short-lived HMAC creds, so no static TURN password is shipped.
# In /etc/turnserver.conf set: use-auth-secret + static-auth-secret=<TURN_SECRET>
TURN_ENABLED=false
# e.g. turn:cam.example.com:3478?transport=udp,turns:cam.example.com:5349?transport=tcp
TURN_URLS=
TURN_SECRET=
TURN_TTL_SEC=3600

# ── Database (MySQL) — ONLY needed when AUTH_ENABLED=true ─────────────────────
DB_HOST=127.0.0.1
DB_USER=cambridge
DB_PASSWORD=
DB_NAME=cambridge
DB_POOL_SIZE=20

# ── Auth (JWT) — ONLY needed when AUTH_ENABLED=true ──────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Email (Resend or Brevo) — ONLY needed when AUTH_ENABLED=true ──────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_DRY_RUN=true
APP_URL=https://www.theundergroundrailroad.world/cambridge
