# ── CamBridge signaling server config ───────────────────────────────────────
# Copy to ".env" and fill in. Never commit your real .env.

# HTTP / WebSocket bind
HOST=0.0.0.0
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed browser Origins for the WS upgrade.
# Leave EMPTY in development to allow any origin. In production set this to your
# real domain(s), e.g. https://cam.example.com
# NOTE: OBS Browser Source sends no/!= Origin, see ALLOW_NULL_ORIGIN below.
ALLOWED_ORIGINS=

# OBS's embedded browser (CEF) often sends Origin "null" or none. Allow it so
# the viewer page can connect from inside OBS. Keep true unless you have a
# reason not to.
ALLOW_NULL_ORIGIN=true

# Public base URL used to build the broadcaster + OBS viewer links returned by
# POST /api/sessions. e.g. https://cam.example.com  (no trailing slash)
# If empty, links are built from the incoming request Host header.
PUBLIC_BASE_URL=

# Session reclaim: idle sessions older than this (ms) are swept. Default 6h.
SESSION_TTL_MS=21600000

# Passcode length (characters, unambiguous alphabet)
PASSCODE_LENGTH=6

# Max signaling message size in bytes (defends against oversized SDP spam)
MAX_MESSAGE_BYTES=65536

# WebSocket heartbeat interval (ms). Dead peers are pruned after one miss.
HEARTBEAT_INTERVAL_MS=30000

# ── ICE: STUN ────────────────────────────────────────────────────────────────
# Comma-separated STUN URLs. Google's public STUN is fine to start.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ── ICE: TURN (coturn) ───────────────────────────────────────────────────────
# Required for hard NAT / CGNAT / cellular. Uses coturn's `use-auth-secret`
# REST scheme — the server mints short-lived HMAC credentials per client, so no
# static TURN password ever reaches a browser.
#
# In /etc/turnserver.conf you must set the SAME secret:
#   use-auth-secret
#   static-auth-secret=<TURN_SECRET below>
#   realm=cam.example.com
TURN_ENABLED=false
# Comma-separated TURN URLs. Include both UDP and TCP/TLS for best reach:
#   turn:cam.example.com:3478?transport=udp,turn:cam.example.com:3478?transport=tcp,turns:cam.example.com:5349?transport=tcp
TURN_URLS=
TURN_SECRET=
TURN_TTL_SEC=3600
