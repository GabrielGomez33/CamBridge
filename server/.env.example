# ── CamBridge server config ─────────────────────────────────────────────────
# Copy to ".env" and fill in. Never commit your real .env.

# HTTP / WebSocket
HOST=0.0.0.0
CAMBRIDGE_PORT=8447
NODE_ENV=development
LOG_LEVEL=info
BASE_PATH=/cambridge

# Reverse-proxy hops so req.ip is the real client (nginx in front). 1 is typical.
TRUST_PROXY_HOPS=1

# Allowed browser Origins for the WS upgrade. Empty = allow any (dev only).
# Production: set to your domain(s), e.g. https://cam.example.com
ALLOWED_ORIGINS=
# OBS's embedded browser (CEF) often sends Origin "null" or none — allow it.
ALLOW_NULL_ORIGIN=true

# Public base URL for building broadcaster + OBS viewer links (no trailing /).
# If empty, links are derived from the incoming request host.
PUBLIC_BASE_URL=

# ── Sessions / abuse limits (DoS resistance) ─────────────────────────────────
SESSION_TTL_MS=21600000
PASSCODE_LENGTH=6
MAX_LIVE_SESSIONS=500
CREATE_RATE_LIMIT=20
CREATE_RATE_WINDOW_MS=60000
MAX_MESSAGE_BYTES=65536
HEARTBEAT_INTERVAL_MS=30000

# Require a logged-in account to create a link (Phase 1 auth). Default open.
REQUIRE_AUTH_TO_CREATE=false

# ── ICE: STUN ────────────────────────────────────────────────────────────────
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ── ICE: TURN (coturn) ───────────────────────────────────────────────────────
# Required for hard NAT / CGNAT / cellular. coturn `use-auth-secret` scheme —
# the server mints short-lived HMAC creds, so no static TURN password is shipped.
# In /etc/turnserver.conf set: use-auth-secret + static-auth-secret=<TURN_SECRET>
TURN_ENABLED=false
# e.g. turn:cam.example.com:3478?transport=udp,turns:cam.example.com:5349?transport=tcp
TURN_URLS=
TURN_SECRET=
TURN_TTL_SEC=3600

# ── Phase 1: Database (MySQL) ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_USER=cambridge
DB_PASSWORD=
DB_NAME=cambridge
DB_POOL_SIZE=20

# ── Phase 1: Auth (JWT) ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Phase 1: Email (Resend or Brevo) ─────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_DRY_RUN=true
APP_URL=
